# Database Configuration (MOVE FROM database.php)
DB_HOST=localhost
DB_USER=asplan_user
DB_PASS=secure_password_here
DB_NAME=osas_db

# Email Configuration (MOVE FROM email.php)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
LARAVEL_BRIDGE_BASE_URL=https://your-domain.com/laravel-app/public

# Session Settings
SESSION_TIMEOUT=1800
SECURE_COOKIES=true

# Gradual Laravel migration toggle
USE_LARAVEL_BRIDGE=0
USE_LARAVEL_AUTH_BRIDGE=0
