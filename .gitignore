# PEAS - Pre-Enrollment Assessment System
# .gitignore file

# Sensitive Configuration Files
config/email.php
!config/email.php
config/credentials.php
.env
.env.local

# Uploaded Files
uploads/*
!uploads/.gitkeep
adviser/uploads/

# IDE and Editor Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
debug_*.log

# Temporary and Debug Files
tmp/
temp/
cache/
debug_*.php
test_*.php
check_*.php
!auth/check_auto_login.php
!auth/check_remember_me.php
fix_*.php

# Database Files
*.sql
!dev/osas_db_041626.sql
*.sqlite
*.db

# Backup Files
*.bak
*.backup
*~

# PHP Specific
vendor/
laravel-app/vendor/
laravel-app/node_modules/
laravel-app/.env
laravel-app/.env.*
!laravel-app/.env.example
laravel-app/_tmp_*.json
laravel-app/storage/logs/*.log
laravel-app/storage/framework/cache/*
laravel-app/storage/framework/sessions/*
laravel-app/storage/framework/views/*
composer.phar
composer.lock
!laravel-app/composer.lock

# Session Files
sessions/
var/

# Error Logs
error_log
php_errors.log
